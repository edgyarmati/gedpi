{
  "name": "gedpi",
  "version": "0.19.0",
  "description": "Single-agent Pi package that clarifies requests, documents the spec, and implements work in bounded slices.",
  "type": "module",
  "license": "MIT",
  "author": "Eduard-David Gyarmati",
  "repository": {
    "type": "git",
    "url": "https://github.com/edgyarmati/ged-mono"
  },
  "homepage": "https://github.com/edgyarmati/ged-mono#readme",
  "bugs": {
    "url": "https://github.com/edgyarmati/ged-mono/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "gedpi": "bin/gedpi.js"
  },
  "keywords": [
    "pi-package",
    "pi",
    "agent",
    "planning",
    "implementation",
    "clarification"
  ],
  "files": [
    "bin",
    "agents",
    "CHANGELOG.md",
    "extensions",
    "themes",
    "prompts",
    "skills",
    "src",
    "templates",
    "vendor/pi-diff-review",
    "README.md",
    "CREDITS.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "chat": "node ./bin/gedpi.js",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "verify": "npm run check && npm run lint && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "pi": {
    "extensions": [
      "./extensions/ged-core/index.ts",
      "./node_modules/pi-web-access/index.ts",
      "./node_modules/pi-subagents/src/extension/index.ts",
      "./node_modules/pi-intercom/index.ts",
      "./vendor/pi-diff-review/src/index.ts",
      "./node_modules/pi-prompt-template-model/index.ts",
      "./node_modules/@plannotator/pi-extension/index.ts",
      "./node_modules/@howaboua/pi-codex-conversion/src/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/glimpseui/skills",
      "./node_modules/pi-web-access/skills",
      "./node_modules/pi-prompt-template-model/skills",
      "./node_modules/@plannotator/pi-extension/skills",
      "./node_modules/pi-subagents/skills",
      "./node_modules/pi-intercom/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.77.0",
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@earendil-works/pi-tui": "0.77.0",
    "@howaboua/pi-codex-conversion": "1.5.21",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@0.77.0",
    "@mariozechner/pi-tui": "npm:@earendil-works/pi-tui@0.77.0",
    "@plannotator/pi-extension": "0.19.27",
    "glimpseui": "0.8.1",
    "jiti": "^2.7.0",
    "pi-intercom": "0.6.0",
    "pi-prompt-template-model": "^0.9.1",
    "pi-subagents": "0.25.0",
    "pi-web-access": "^0.10.7"
  },
  "overrides": {
    "@mozilla/readability": "0.6.0",
    "picomatch": "4.0.4",
    "vite": "7.3.2"
  }
}
